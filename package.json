{
  "name": "@joinbankroll/sdk",
  "version": "0.4.0",
  "description": "Build on Bankroll — typed client for the window.bankroll bridge, plus server-side session verification, charge confirmation, and payouts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inplayinnovation/bankroll-sdk.git"
  },
  "homepage": "https://joinbankroll.com",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./privy": {
      "types": "./dist/privy.d.ts",
      "import": "./dist/privy.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/spl-token": "0.4.15",
    "@solana/web3.js": "1.98.4",
    "bs58": "6.0.0",
    "jose": "^6.0.0"
  },
  "peerDependencies": {
    "@privy-io/node": "^0.10.1"
  },
  "peerDependenciesMeta": {
    "@privy-io/node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@privy-io/node": "^0.10.1",
    "@types/node": "^24.0.0",
    "happy-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
