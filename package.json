{
  "name": "@joinbankroll/sdk",
  "version": "0.2.1",
  "description": "Build on Bankroll — typed client for the window.bankroll bridge and server-side session token verification",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inplayinnovation/bankroll-sdk.git"
  },
  "homepage": "https://joinbankroll.com",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "happy-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
